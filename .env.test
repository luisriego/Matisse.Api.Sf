KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
SYMFONY_DEPRECATIONS_HELPER=999999
PANTHER_APP_ENV=panther
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots

#DATABASE_URL="sqlite:///%kernel.project_dir%/var/test.db"

# IMPORTANT: must NOT be the same database as dev (.env). Integration tests TRUNCATE all tables.
# Use a single "_test" in the database NAME (app_test). config/packages/test/doctrine.yaml disables
# Doctrine's dbname_suffix so the URL is not turned into app_test_test.
# Create once: docker exec matisse-db psql -U app -d postgres -c "CREATE DATABASE app_test;"
# Then migrate (or, if migrate fails on empty DB: create extension vector on app_test, then doctrine:schema:update --force --env=test)
#   php bin/console doctrine:migrations:migrate --env=test --no-interaction
DATABASE_URL="postgresql://app:password@matisse-db:5432/app_test?serverVersion=16&charset=utf8"

# .env.test
API_ACCESS_ROLE=IS_AUTHENTICATED_FULLY

SETTLEMENT_INCOME_SPLIT_ENABLED=0
SETTLEMENT_SPLIT_BASE_ACCOUNT_ID=
SETTLEMENT_SPLIT_BASE_INCOME_TYPE_ID=
SETTLEMENT_SPLIT_SYNDIC_ACCOUNT_ID=
SETTLEMENT_SPLIT_SYNDIC_INCOME_TYPE_ID=
SETTLEMENT_SPLIT_EXTRA_ACCOUNT_ID=
SETTLEMENT_SPLIT_EXTRA_INCOME_TYPE_ID=
SETTLEMENT_SPLIT_RESERVE_ACCOUNT_ID=
SETTLEMENT_SPLIT_RESERVE_INCOME_TYPE_ID=
SETTLEMENT_SPLIT_GAS_ACCOUNT_ID=
SETTLEMENT_SPLIT_GAS_INCOME_TYPE_ID=
