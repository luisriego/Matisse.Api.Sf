###> BankStatement / OFX ###
# Optional default IncomeType id applied to OFX CREDIT lines when client does not send incomeTypeId.
DEFAULT_BANK_CREDIT_INCOME_TYPE_ID=
# Split boleto settlement into several incomes by slip component.
# Accounts and income types are resolved from DB by name — no UUIDs needed.
SETTLEMENT_INCOME_SPLIT_ENABLED=1
