# Copy to .env.local on the server and adjust values.
# cp .env.server.dist .env.local

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-generate-with-openssl-rand-hex-16
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://app:CHANGE_DB_PASSWORD@matisse-db:5432/app?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> server / docker-compose.server.yml ###
U_ID=1000
APP_PORT=8080
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_DB_PASSWORD
###< server / docker-compose.server.yml ###

###> nelmio/cors-bundle ###
# Allow your frontend origin(s). For quick testing you can use a broad regex:
CORS_ALLOW_ORIGIN='^https?://(.*)$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=true
###< symfony/messenger ###

###> symfony/mailer ###
# Produccion con Mailtrap Sending (live.smtp.mailtrap.io). Sustituye USER y PASS por los de
# tu cuenta (Email Sending -> SMTP/API -> Integration -> SMTP).
MAILER_DSN=smtp://MAILTRAP_USER:MAILTRAP_PASS@live.smtp.mailtrap.io:587
# Alternativa Brevo: MAILER_DSN=smtp://BREVO_LOGIN:BREVO_SMTP_KEY@smtp-relay.brevo.com:587
# Para desactivar emails temporalmente: MAILER_DSN=null://null
# Remitente unico (debe ser un dominio verificado en el proveedor).
MAILER_FROM=no-reply@luisriego.dev
###< symfony/mailer ###

###> app base url (enlaces en emails: activacion, reset password) ###
APP_BASE_URL=https://matisse.luisriego.dev
APP_FRONT_SIGNIN_PATH=/signin
APP_FRONT_SET_PASSWORD_PATH=/set-password
###< app base url ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me-jwt-passphrase
JWT_TTL=2592000
###< lexik/jwt-authentication-bundle ###

###> app ###
API_ACCESS_ROLE=IS_AUTHENTICATED_FULLY
###< app ###

###> BankStatement / OFX (optional for play) ###
DEFAULT_BANK_CREDIT_INCOME_TYPE_ID=
SETTLEMENT_INCOME_SPLIT_ENABLED=1
###< BankStatement / OFX ###

# Ollama is NOT started by docker-compose.server.yml (BankStatement embeddings optional).
OLLAMA_HOST=
OLLAMA_EMBEDDING_MODEL=
