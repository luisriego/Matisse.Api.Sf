<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Context\BankStatement\Domain\ExpenseEmbedding" table="expense_embedding">
        <id name="id" type="uuid" column="id">
            <generator strategy="NONE"/>
        </id>

        <field name="expenseId"      column="expense_id"      type="uuid"               />
        <field name="vector"         column="vector"          type="vector"  />
        <field name="description"    column="description"     type="text"               />
        <field name="embeddingModel" column="embedding_model" type="string" length="100"/>
        <field name="indexedAt"      column="indexed_at"      type="datetime_immutable" />

        <unique-constraints>
            <unique-constraint columns="expense_id" name="uq_expense_embedding_expense_id"/>
        </unique-constraints>
    </entity>

</doctrine-mapping>
